import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.metrics import r2_score, mean_squared_error
import matplotlib.pyplot as plt
import seaborn as sns
import warnings

warnings.filterwarnings("ignore", category=RuntimeWarning)

df = pd.read_csv("C:\\Users\\aarya\\OneDrive\\Desktop\\code\\ML Portfolio\\001_LinearRegression\\data.csv")  # https://www.kaggle.com/datasets/awaiskaggler/insurance-csv?
                                                               # refernce for the dataset taken from kaggle
                                                               # name Insurance csv
df['sex'] = df['sex'].map({'male': 0, 'female': 1})
df['smoker'] = df['smoker'].map({'no': 0, 'yes': 1})
df = pd.get_dummies(df, columns=['region'], drop_first=True)
df = df.astype(float)                                         # used to avoid perfect multi-collinearity, so one option is dropped and others are predicted using it
                                                              # important in regression prediction for categorical columns

target_col = 'expenses'  # target here is expenses column, target is the value we attempt to predict based on various features(factors affecting the target)

X_train, X_test, y_train, y_test = train_test_split(
    df.drop(target_col, axis=1).values,
    df[target_col].values,
    test_size=0.2,
    random_state=42
)

X_mean = X_train.mean(axis=0)
X_std = X_train.std(axis=0)
print("Mean of training data:")
print(X_mean)
print("\n Standard deviation of training data")
print(X_std)
X_train = (X_train - X_mean) / X_std
X_test = (X_test - X_mean) / X_std
print("\nAfter Normailization(training data): ")
print(X_train)
print("\nAfter Normailization(test data): ")
print(X_test)
X_train = np.c_[np.ones(X_train.shape[0]), X_train]
X_test = np.c_[np.ones(X_test.shape[0]), X_test]

def normal_equation(X, y):
    return np.linalg.pinv(X.T @ X) @ X.T @ y#closed form to calculate/predict using normal equation

theta = normal_equation(X_train, y_train)

y_pred = X_test @ theta
r2 = r2_score(y_test, y_pred)
rmse = np.sqrt(mean_squared_error(y_test, y_pred))

print("------------MODEL PERFORMANCE---------")
print(f"R^2 Score : {r2:.3f}")
print(f"RMSE     : {rmse:.2f}")
print("-------------------------------------------------\n")

feature_names = ['Intercept', 'age', 'sex', 'bmi', 'children', 'smoker',
                 'region_northwest', 'region_southeast', 'region_southwest']

print("Feature Coefficients:")
for name, coef in zip(feature_names, theta):
    print(f"{name:20s}: {coef:.3f}")
print("----------------------------------------------\n")

def predict_expense(age, sex, bmi, children, smoker, region):  # function for input data
    if sex.lower() == 'female':  # categorical data needs to be converted to numeric
        sex = 1
    else:
        sex = 0
    if smoker.lower() == 'yes':
        smoker = 1
    else:
        smoker = 0

    if region.lower() == 'northwest':
        region_northwest = 1
    else:
        region_northwest = 0
    if region.lower() == 'southeast':
        region_southeast = 1
    else:
        region_southeast = 0
    if region.lower() == 'southwest':
        region_southwest = 1
    else:
        region_southwest = 0

    user_input = np.array([age, sex, bmi, children, smoker,
                           region_northwest, region_southeast, region_southwest])  # we create a array in the same ordeer as the data set, maintaining order is important to make sure inputs match correctly

    user_input = (user_input - X_mean) / X_std  # Normalize using training data set's mean and std
    user_input = np.insert(user_input, 0, 1)  # adding 1 in 0th index to make sure that the structure is same and the bias element is accurately computed

    predicted_expense = user_input @ theta  # y_predicted = theta.X(input_feature)
    return predicted_expense

